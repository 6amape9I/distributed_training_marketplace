SERVICE_NAME=evaluator-agent
EVALUATOR_NODE_ID=evaluator-1
ORCHESTRATOR_BASE_URL=http://orchestrator:8000
EVALUATOR_BIND_HOST=0.0.0.0
EVALUATOR_BIND_PORT=8020
EVALUATOR_PUBLIC_URL=http://evaluator-1:8020
HEARTBEAT_INTERVAL_SECONDS=10
TASK_POLL_INTERVAL_SECONDS=2
LOCAL_WORKSPACE_PATH=/app/data/evaluator-1
EVALUATOR_CAPABILITIES_JSON={"metrics":["accuracy","average_loss"]}
ENABLE_BACKGROUND_WORKERS=true
